# Owner identity for local builds — copy to scripts/identity.env (gitignored)
# and fill in your values. scripts/build.sh sources it; RELAYOUT_* environment
# variables with the same names take precedence (the ${X:-...} form below).
# CI does not use this file — it reads repository variables instead
# (see docs/RELEASING.md → "Forking").
#
# Without this file local builds still work, under a neutral identity:
# bundle id com.example.relayout(.dev), repo slug from the git origin remote,
# Sparkle update checks disabled.

# Base bundle id; dev builds append ".dev" (separate Accessibility grant).
export RELAYOUT_BUNDLE_ID="${RELAYOUT_BUNDLE_ID:-com.example.relayout}"

# App display name; dev builds append " (dev)".
export RELAYOUT_DISPLAY_NAME="${RELAYOUT_DISPLAY_NAME:-reLayout}"

# GitHub owner/repo — the About link in Settings.
export RELAYOUT_REPO_SLUG="${RELAYOUT_REPO_SLUG:-example/reLayout}"

# Sparkle appcast URL. Leave empty to disable update checks in local builds.
export RELAYOUT_FEED_URL="${RELAYOUT_FEED_URL:-}"

# Sparkle EdDSA PUBLIC key — pairs with the SPARKLE_ED_PRIVATE_KEY CI secret;
# always replace both together (docs/RELEASING.md).
export RELAYOUT_SU_PUBLIC_KEY="${RELAYOUT_SU_PUBLIC_KEY:-}"

# Homebrew tap owner/name (used by packaging/homebrew/update-cask.sh, CI-only).
export RELAYOUT_TAP_REPO="${RELAYOUT_TAP_REPO:-example/homebrew-relayout}"
